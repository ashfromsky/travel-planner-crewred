# Database connection URL (using aiosqlite driver for async support)
DATABASE_URL=sqlite+aiosqlite:///./db.sqlite3

# Third-party Art Institute of Chicago API base URL
AIC_BASE_URL=https://api.artic.edu/api/v1

# Granian ASGI server configuration
HOST=0.0.0.0
PORT=8000

# Number of worker processes. Keep WORKERS=1 when using SQLite to avoid database write locks/conflicts.
WORKERS=1